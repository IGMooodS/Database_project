SET search_path TO philately ;

-- Групповые роли (без LOGIN)
CREATE ROLE role_fa_managers NOLOGIN;
CREATE ROLE role_ufps_heads  NOLOGIN;
CREATE ROLE role_reg_analyst NOLOGIN;
CREATE ROLE role_order_ops   NOLOGIN;

-- Примеры пользователей
CREATE ROLE u_fa_mgr_1   LOGIN PASSWORD '1';
CREATE ROLE u_ufps_head_1 LOGIN PASSWORD '1';
CREATE ROLE u_analyst_1  LOGIN PASSWORD '1';
CREATE ROLE u_operator_1 LOGIN PASSWORD '1';

